        {
            "@id": "bts:ArrayManufacturer",
            "@type": "rdfs:Class",
            "rdfs:comment": "Manufacturer of the genotyping array used for the discovery stage. Separate multiple manufacturers by a semicolon (;). Example - Illumina, Affymetrix, Perlegen",
            "rdfs:label": "ArrayManufacturer",
            "rdfs:subClassOf": [
                {
                    "@id": "bts:manifestColumn"
                }
            ],
